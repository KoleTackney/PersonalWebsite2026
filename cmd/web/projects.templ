package web

templ ProjectsPage() {
	@Base("/projects") {
		<section class="max-w-5xl mx-auto px-6 pt-32 pb-16">
			<h1 class="text-4xl font-bold text-white mb-3">Projects</h1>
			<p class="text-neutral-500 text-lg mb-14 max-w-2xl">
				A selection of things I've built &mdash; from production systems to side projects.
			</p>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				@ProjectCard(Project{
					Name:        "SousChef",
					Description: "AI-powered cooking assistant with recipe generation, a searchable recipe library, user accounts, and a Kitchen Notebook journal. Full-stack app with polished UI.",
					Tags:        []string{"TypeScript", "React", "ElysiaJS", "Bun", "Tailwind CSS", "SQLite", "Claude API"},
					Link:        "https://github.com/KoleTackney",
					LiveURL:     "https://sous-chef.koletackney.dev/",
					Featured:    true,
				})
				@ProjectCard(Project{
					Name:        "You.i Engine VSCode Extension",
					Description: "Production VSCode extension for the You.i Engine C++ SDK. Widely used across the development team at Warner Media for daily workflow tooling.",
					Tags:        []string{"TypeScript", "VSCode API"},
					Link:        "https://github.com/KoleTackney",
					Featured:    false,
				})
				@ProjectCard(Project{
					Name:        "LoRA Stacker CivitAI Tags",
					Description: "Published ComfyUI custom node that auto-fetches trained trigger words for every LoRA in a stack from the CivitAI API. Caches results locally and passes the stack through unchanged.",
					Tags:        []string{"Python", "ComfyUI", "CivitAI API"},
					Link:        "https://github.com/KoleTackney/lora-stacker-civitai-tags",
					LiveURL:     "https://registry.comfy.org/publishers/kolet/nodes/lora-stacker-civitai-tags",
					Featured:    false,
				})
				@ProjectCard(Project{
					Name:        "Short Link",
					Description: "Personal URL shortener built to experiment with Templ UI. Create and manage short links backed by SQLite. Hosted on Railway.",
					Tags:        []string{"Go", "Templ", "SQLite", "Tailwind CSS"},
					LiveURL:     "https://short.koletackney.dev/",
					Featured:    false,
				})
				@ProjectCard(Project{
					Name:        "koletackney.dev",
					Description: "This website. Built with Go, Templ, HTMX, and Tailwind CSS. Server-side rendered with no JS framework. Hosted on Railway.",
					Tags:        []string{"Go", "Templ", "HTMX", "Tailwind CSS"},
					Link:        "https://github.com/KoleTackney",
					Featured:    false,
				})
			</div>
		</section>
	}
}

type Project struct {
	Name        string
	Description string
	Tags        []string
	Link        string
	LiveURL     string
	Featured    bool
}

templ ProjectCard(project Project) {
	<div class={ "glass-card rounded-2xl p-7 group relative flex flex-col", templ.KV("md:col-span-2", project.Featured), templ.KV("cursor-pointer", project.LiveURL != "" || project.Link != "") }>
		if project.LiveURL != "" {
			<a href={ templ.SafeURL(project.LiveURL) } target="_blank" rel="noopener" class="absolute inset-0 rounded-2xl" aria-label={ project.Name }></a>
		} else if project.Link != "" {
			<a href={ templ.SafeURL(project.Link) } target="_blank" rel="noopener" class="absolute inset-0 rounded-2xl" aria-label={ project.Name }></a>
		}
		<div class="relative z-10 flex items-center justify-between mb-4">
			<h3 class="text-xl font-bold text-white group-hover:text-amber-400 transition-colors">{ project.Name }</h3>
			if project.Featured {
				<span class="badge-featured text-xs px-3 py-1 rounded-full font-medium tracking-wide">Featured</span>
			}
		</div>
		<p class="relative z-10 text-neutral-400 text-sm leading-relaxed mb-5">{ project.Description }</p>
		<div class="relative z-10 flex flex-wrap gap-2 mb-5">
			for _, tag := range project.Tags {
				<span class="tag-pill text-xs text-neutral-400 px-2.5 py-1 rounded-full">{ tag }</span>
			}
		</div>
		<div class="relative z-10 flex items-center gap-4 mt-auto">
			if project.LiveURL != "" {
				<a href={ templ.SafeURL(project.LiveURL) } target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-sm text-amber-400 hover:text-amber-300 transition-colors font-medium">
					Visit Site <span class="text-xs">&rarr;</span>
				</a>
			}
			if project.Link != "" {
				<a href={ templ.SafeURL(project.Link) } target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-sm text-neutral-500 hover:text-neutral-300 transition-colors font-medium">
					View on GitHub <span class="text-xs">&rarr;</span>
				</a>
			}
			if project.LiveURL == "" && project.Link == "" {
				<span class="text-sm text-neutral-600 italic">Private repository</span>
			}
		</div>
	</div>
}
